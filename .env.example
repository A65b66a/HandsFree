# ai-book-narrator configuration
# Copy this file to .env and fill in your values.

# Required for Emotional narration mode with StyleTTS2.
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Ollama endpoint (default works for local installation).
# Change if Ollama runs on a different host/port.
OLLAMA_URL=http://localhost:11434/api/generate

# Ollama model for script rewriting and book analysis.
# llama3.2:3b is a good balance of speed and quality.
OLLAMA_MODEL=llama3.2:3b
